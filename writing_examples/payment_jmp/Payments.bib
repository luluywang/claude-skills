@article{Weyl2010,
  title = {A {{Price Theory}} of {{Multi-Sided Platforms}}},
  author = {Weyl, E. Glen},
  date = {2010-09},
  journaltitle = {American Economic Review},
  volume = {100},
  number = {4},
  pages = {1642--1672},
  issn = {0002-8282},
  doi = {10.1257/aer.100.4.1642},
  abstract = {I develop a general theory of monopoly pricing of networks. Platforms use insulating tariffs to avoid coordination failure, implementing any desired allocation. Profit maximization distorts in the spirit of A. Michael Spence (1975) by internalizing only network externalities to marginal users. Thus the empirical and prescriptive content of the popular Jean-Charles Rochet and Jean Tirole (2006) model of two-sided markets turns on the nature of user heterogeneity. I propose a more plausible, yet equally tractable, model of heterogeneity in which users differ in their income or scale. My approach provides a general measure of market power and helps predict the effects of price regulation and mergers. (JEL D42, D85, L14)},
  langid = {english}
}

@article{White.Weyl2016,
  title = {Insulated {{Platform Competition}}},
  author = {White, Alexander and Weyl, E. Glen},
  date = {2016},
  journaltitle = {SSRN Electronic Journal},
  issn = {1556-5068},
  doi = {10.2139/ssrn.1694317},
  abstract = {Does competition promote efficient platform pricing and market structures? We model imperfect platform competition using a new approach, Insulated Equilibrium (IE). Building on the observation that platforms often charge low prices to build a “critical mass”, IE assumes platforms use “penetration pricing” to simplify the role of user beliefs. We show that competition's impact on efficiency depends crucially on heterogeneity in users' valuations for network effects. The standard Flat Pricing approach (FP) cannot tractably incorporate such heterogeneity. We show that IE's sharp, general predictions are economically similar to FP's, when FP is tractable, and we show how the nature of product differentiation determines the welfare consequences of competition in calibrated models of the video game and newspaper industries.},
  langid = {english}
}

