  author = {Song, Minjae},
  date = {2021-05-01},
  journaltitle = {American Economic Journal: Microeconomics},
  shortjournal = {American Economic Journal: Microeconomics},
  volume = {13},
  number = {2},
  pages = {35--67},
  issn = {1945-7669, 1945-7685},
