@article{Ambrus.Argenziano2009,
  title = {Asymmetric {{Networks}} in {{Two-Sided Markets}}},
  author = {Ambrus, Attila and Argenziano, Rossella},
  date = {2009-01},
  journaltitle = {American Economic Journal: Microeconomics},
  volume = {1},
  number = {1},
