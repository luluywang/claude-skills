@online{Liebersohn.etal2024,
  type = {SSRN Scholarly Paper},
  title = {Understanding {{Excess Repayment}}},
  author = {Liebersohn, Jack and Jambulapati, Vikram and Fitzpatrick, Michael},
  date = {2024-09-06},
