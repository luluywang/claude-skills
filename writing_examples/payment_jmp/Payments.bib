@article{Weiner.Wright2005,
  title = {Interchange {{Fees}} in {{Various Countries}}: {{Developments}} and {{Determinants}}},
  shorttitle = {Interchange {{Fees}} in {{Various Countries}}},
  author = {Weiner, Stuart E. and Wright, Julian},
  date = {2005-12},
