@article{Piazzesi.Schneider2022,
  title = {Credit Lines, Bank Deposits or {{CBDC}}? {{Competition}} \& Efficiency in Modern Payment Systems},
  author = {Piazzesi, Monika and Schneider, Martin},
  date = {2022-06},
  pages = {36},
  abstract = {This paper studies the welfare effects of introducing a Central Bank Digital Currency (CBDC). Its premise is that CBDC is a new product in the market for liquidity where it competes with both commercial bank deposits and credit lines used for payments. If the central bank offers CBDC but not credit lines, then it interferes with the complementarity between credit lines and deposits built into modern payment systems. As a result, increasing CBDC may reduce welfare even if the central bank can provide deposits more cheaply than commercial banks.},
