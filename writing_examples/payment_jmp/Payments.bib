@incollection{Bramoulle.Kranton2016,
  title = {Games {{Played}} on {{Networks}}},
  booktitle = {The {{Oxford Handbook}} of the {{Economics}} of {{Networks}}},
  author = {Bramoullé, Yann and Kranton, Rachel},
  namea = {Bramoullé, Yann and Kranton, Rachel},
