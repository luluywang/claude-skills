@report{Fuster.etal2021,
  type = {Working paper (Federal Reserve Bank of Philadelphia)},
  title = {Does {{CFPB Oversight Crimp Credit}}?},
  author = {Fuster, Andreas and Plosser, Matthew and Vickery, James and Marco Scanlon, Madeline},
  date = {2021-02},
